// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum userRole {
  ADMIN
  USER
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String
  role       userRole @default(USER)
  createdAt  DateTime @default(now())
  updatedAT  DateTime @updatedAt
  provider   String   @default("app-auth")
}

enum ProductTypes {
  TABLET
  SYRUP
  CAPSULE
  INJECTION
  OINTMENT
  DROPS
  OTHER
}

enum ProductCatType {
  PCD
  THIRDPARTY
}

model Product {
  id            String       @id @default(uuid())
  name          String
  description   String?      // Detailed info about the product
  type          ProductTypes // Enum for structured type
  category      ProductCatType // Enum for product category
  clicks        Int          @default(0) // Track popularity
  isActive      Boolean      @default(true) // Soft delete or availability flag
  ingredients   String?      // Optional: list of active ingredients
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  image         String       // Main image URL (from ImageKit)
  thumbnail     String?      // Optional: smaller image
  rating        Float?       // Optional: average rating
  reviewsCount  Int?         // Optional: number of reviews
  reviews       Review[]     // Optional: array of reviews
}

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String
  userName  String
  rating    Int      // 1-5
  comment   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // one review per user per product
}